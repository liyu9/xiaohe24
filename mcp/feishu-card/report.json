{
  "_description": "数据报告卡片（绿色 header + 列表 + 链接按钮）。变量：{TITLE}/{SUBTITLE}/{ITEMS}/{BUTTON_URL}/{BUTTON_LABEL}。",
  "_usage": "ITEMS 是 markdown 格式的多行文本，每条用 \\n---\\n 分隔。",
  "msg_type": "interactive",
  "card": {
    "config": {"wide_screen_mode": true},
    "header": {
      "title": {"content": "📊 {TITLE}", "tag": "plain_text"},
      "template": "green"
    },
    "elements": [
      {
        "tag": "markdown",
        "content": "{SUBTITLE}\n\n---\n\n{ITEMS}"
      },
      {
        "tag": "action",
        "actions": [
          {
            "tag": "button",
            "text": {"tag": "plain_text", "content": "📈 查看详情"},
            "type": "primary",
            "url": "{BUTTON_URL}"
          },
          {
            "tag": "button",
            "text": {"tag": "plain_text", "content": "🔄 刷新"},
            "type": "default",
            "value": {"action": "refresh"}
          }
        ]
      }
    ]
  }
}
